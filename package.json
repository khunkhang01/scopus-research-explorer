{
  "name": "scopus-research-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark:parser": "node scripts/benchmark-parser.mjs 10000",
    "benchmark:parser:malformed": "node scripts/benchmark-parser.mjs 10000 --malformed",
    "smoke:obsidian": "node scripts/cdp-smoke.mjs",
    "contract:obsidian": "node scripts/cdp-contract.mjs",
    "restore:obsidian": "node scripts/cdp-restore.mjs",
    "performance:obsidian": "node scripts/cdp-performance.mjs",
    "cleanup:obsidian": "node scripts/cdp-cleanup.mjs",
    "verify:obsidian": "node scripts/runtime-suite.mjs",
    "validate:real-export": "node scripts/cdp-real-export.mjs",
    "quality:prepare": "node scripts/cdp-prepare-quality.mjs",
    "quality:evaluate": "node scripts/evaluate-quality.mjs",
    "quality:self-test": "node scripts/quality-self-test.mjs",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "cytoscape": "3.34.0",
    "papaparse": "5.5.4"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^24.0.0",
    "@types/papaparse": "^5.3.16",
    "esbuild": "0.28.1",
    "obsidian": "1.13.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
